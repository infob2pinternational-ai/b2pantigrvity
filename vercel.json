{
  "rewrites": [
    {
      "source": "/billing",
      "destination": "https://document-gen-ten.vercel.app/billing"
    },
    {
      "source": "/billing/:path*",
      "destination": "https://document-gen-ten.vercel.app/billing/:path*"
    },
    {
      "source": "/doc/:path*",
      "destination": "https://document-gen-ten.vercel.app/doc/:path*"
    },
    {
      "source": "/((?!assets/|static/|api/|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ]
}
